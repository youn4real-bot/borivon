# ──────────────────────────────────────────────────────────────────────────────
# Borivon — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Your project's URL (safe to expose in client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — public, used in browser and JWT verification
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Service role key — SECRET, server-side only, bypasses Row-Level Security
# Never expose this in client code or NEXT_PUBLIC_* variables
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Full email address of the primary admin account
# Server-only — never use NEXT_PUBLIC_ADMIN_EMAIL
ADMIN_EMAIL=admin@borivon.com

# ─── Google Drive (document storage) ──────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# Multi-line key — use literal \n for newlines in .env.local
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# The Drive folder ID where uploaded documents are stored
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWx

# ─── OCR (document text extraction) ───────────────────────────────────────────
# Azure Document Intelligence (primary OCR engine)
AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=abc123...

# Google Vision API (fallback OCR — used when Azure fails)
GOOGLE_VISION_KEY=AIza...

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Base URL used for email links (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://borivon.com

# ─── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Bot protection (Cloudflare Turnstile) ────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...
TURNSTILE_SECRET_KEY=0x4AAA...
