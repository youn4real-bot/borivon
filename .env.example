# ──────────────────────────────────────────────────────────────────────────────
# Borivon — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Your project's URL (safe to expose in client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — public, used in browser and JWT verification
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Service role key — SECRET, server-side only, bypasses Row-Level Security
# Never expose this in client code or NEXT_PUBLIC_* variables
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Full email address of the primary admin account
# Server-only — never use NEXT_PUBLIC_ADMIN_EMAIL
ADMIN_EMAIL=admin@borivon.com

# ─── Google Drive (document storage) ──────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# Multi-line key — use literal \n for newlines in .env.local
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# The Drive folder ID where uploaded documents are stored
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWx

# ─── Cloudflare R2 (file storage — replacing Google Drive) ────────────────────
# All SECRET, server-side only. Get these from R2 → Manage API Tokens.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=borivon-files
# The S3 endpoint Cloudflare showed you, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ─── OCR (document text extraction) ───────────────────────────────────────────
# Azure Document Intelligence (primary OCR engine)
AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=abc123...

# Google Vision API (fallback OCR — used when Azure fails)
GOOGLE_VISION_KEY=AIza...

# ─── AI assistant (Google Gemini on Vertex AI, EU region) ────────────────────
# Powers the admin AI assistant (app/api/portal/admin/assistant). Runs Gemini on
# VERTEX (not the AI-Studio key) so candidate data stays in the EU under Google's
# Vertex DPA. With these unset the assistant returns a friendly 503 ("not
# connected") — the feature ships inert until the key is added.
#   1. Google Cloud → enable the "Vertex AI API" in your project.
#   2. Create a Service Account with the "Vertex AI User" role → JSON key.
#   3. Paste the WHOLE JSON of that key as GOOGLE_VERTEX_CREDENTIALS (one line).
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=europe-west4
GOOGLE_VERTEX_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Optional — override the model without a code change (default: gemini-2.5-flash)
# ASSISTANT_MODEL_ID=gemini-2.5-flash

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Base URL used for email links (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://borivon.com

# ─── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Bot protection (Cloudflare Turnstile) ────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...
TURNSTILE_SECRET_KEY=0x4AAA...

# ─── Academy live classes (Daily.co — OPTIONAL, auto-attendance) ──────────────
# Leave BOTH unset to keep manual attendance only — the Academy works without
# these; the video + auto-attendance code stays inert until they exist.
# 1) Create a free account at daily.co, copy the API key (Developers → API keys).
DAILY_API_KEY=
# 2) After deploying, create a webhook (Daily dashboard / API) pointing at
#    https://www.borivon.com/api/portal/academy/daily-webhook and paste its
#    HMAC secret here so the webhook signature can be verified (fail-closed).
DAILY_WEBHOOK_SECRET=

# ─── Error alerting (OPTIONAL — Slack/Discord incoming webhook) ───────────────
# When set, every unhandled SERVER error is POSTed here (and always logged as
# structured JSON to the platform logs regardless). Leave unset to log-only.
# No SaaS account needed — a Slack or Discord channel webhook URL is enough:
#   Slack:   Channel → Integrations → Incoming Webhooks → copy URL
#   Discord: Channel → Edit → Integrations → Webhooks → New → copy URL
ERROR_WEBHOOK_URL=

# ─── Distributed rate limiting (OPTIONAL — Vercel KV / Upstash Redis) ─────────
# The cost-sensitive endpoints (upload, CV/PDF render, signature, feed post)
# auto-upgrade from a per-instance cap to a HARD GLOBAL cap the moment these
# exist. Vercel → Storage → KV (or an Upstash Redis REST instance) injects them
# automatically. Until then the in-process limiter runs (no code change either way).
KV_REST_API_URL=
KV_REST_API_TOKEN=
